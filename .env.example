# Local dev — copy to .env:  copy .env.example .env
# Use localhost if MongoDB is installed locally, OR paste your Atlas URI below.

MONGODB_URI=mongodb://127.0.0.1:27017/digital-document-generator

# Optional: Atlas standard URI fallback (only if mongodb+srv fails on Render)
# MONGODB_STANDARD_URI=

CORS_ORIGINS=http://localhost:5173

# --- Render Dashboard only (do NOT commit real passwords) ---
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.CLUSTER_ID.mongodb.net/digital-document-generator?retryWrites=true&w=majority
# NODE_ENV=production
# CORS_ORIGINS=https://your-frontend.onrender.com
