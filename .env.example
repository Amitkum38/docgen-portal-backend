# Copy to .env and fill in after creating MongoDB Atlas cluster (see steps below).
MONGODB_URI=mongodb://127.0.0.1:27017/digital-document-generator

# Production on Render — set these in Render Dashboard → Environment (not in git):
# MONGODB_URI=mongodb+srv://<db-user>:<db-password>@cluster0.<cluster-id>.mongodb.net/digital-document-generator?retryWrites=true&w=majority
# NODE_ENV=production
# CORS_ORIGINS=https://your-frontend.onrender.com

# Comma-separated frontend URLs allowed to send cookies (production + dev)
CORS_ORIGINS=http://localhost:5173
