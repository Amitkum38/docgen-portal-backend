MONGODB_URI=mongodb://127.0.0.1:27017/digital-document-generator
# Production (Atlas): paste the SRV string from Atlas → Connect → Drivers
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/digital-document-generator?retryWrites=true&w=majority
# If Render fails with querySrv ENOTFOUND, use Atlas "Standard connection string" here instead:
# MONGODB_STANDARD_URI=mongodb://user:pass@cluster0-shard-00-00.xxxxx.mongodb.net:27017,.../digital-document-generator?ssl=true&replicaSet=...
# Comma-separated frontend URLs allowed to send cookies (production + dev)
CORS_ORIGINS=http://localhost:5173
